{
  "annotations": {
    "readOnlyHint": true,
    "title": "Get discussion"
  },
  "description": "Get discussion metadata by owner, repo, and discussion number. Does not return comments, replies, or comment counts; use get_discussion_comments for comment read/list/summarize/count requests.",
  "inputSchema": {
    "properties": {
      "discussionNumber": {
        "description": "Discussion number. This is not a node ID.",
        "type": "number"
      },
      "owner": {
        "description": "Repository owner or organization login.",
        "type": "string"
      },
      "repo": {
        "description": "Repository name. Use .github for organization-level discussions.",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "discussionNumber"
    ],
    "type": "object"
  },
  "name": "get_discussion"
}